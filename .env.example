# GA App — local development environment template.
#
# Copy to apps/web/.env.local (gitignored) and fill in the values. Never
# commit a real connection string. The deployed app reads these from
# Vercel project environment variables, not from any committed file.
#
# See docs/runbooks/postgres-restore.md for the Neon provisioning checklist.

# --- Postgres (J1.1) -------------------------------------------------------
# Neon connection string. MUST include `sslmode=require`; the env loader in
# `packages/db/src/env.ts` rejects strings without it. Use the **pooled**
# connection (host ends in `-pooler.…`) for the serverless web app and the
# **direct** connection only for migrations / restore drills.
DATABASE_URL=postgres://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/DBNAME?sslmode=require
DATABASE_URL_DIRECT=postgres://USER:PASSWORD@HOST.REGION.aws.neon.tech/DBNAME?sslmode=require

# Optional: Neon API key for tooling that lists projects / triggers PITR.
# Only needed by ops scripts; the application never reads this value.
# NEON_API_KEY=

# --- Blob storage (J2.1) ---------------------------------------------------
# Vercel Blob read/write token. Vercel injects this for the deployed app
# (Project Settings → Storage → Connect → Read/Write Token). The local app
# reads it from apps/web/.env.local. The packages/storage env loader will
# fail loudly if a route handler tries to upload without it.
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_REPLACE_ME

# --- Notifications (H1, PMB-17) -------------------------------------------
# Shared secret used by Vercel Cron to authenticate against the
# /api/cron/notifications route. Vercel sets `Authorization: Bearer
# ${CRON_SECRET}` automatically when the schedule fires. Required in
# every environment — without it the route refuses to run.
CRON_SECRET=REPLACE_ME_WITH_A_LONG_RANDOM_STRING

# Resend API key + verified sender for the transactional notification
# emails. Until both are set, the sweep enqueues rows into email_outbox
# but the drainer uses the NullMailer — rows are marked sent with no
# real delivery so the loop doesn't accumulate forever.
# Sign up at https://resend.com and verify your sending domain.
RESEND_API_KEY=
NOTIFICATIONS_FROM_EMAIL=alerts@example.test
